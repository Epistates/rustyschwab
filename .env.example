# Schwab API Configuration
# Copy this file to .env and fill in your values

# Required: Your Schwab app credentials from developer.schwab.com
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# Required: OAuth callback URL
# For development with cloudflared:
#   1. Run: cloudflared tunnel --url http://localhost:8080
#   2. Use the generated URL (e.g., https://random-name.trycloudflare.com)
# For local testing without tunnel:
#   Use: https://127.0.0.1:8080
SCHWAB_CALLBACK_URL=https://your-tunnel.trycloudflare.com

# Optional: Token storage location (default: schwab_tokens.json)
SCHWAB_TOKENS_FILE=schwab_tokens.json

# Optional: API endpoints (defaults shown)
SCHWAB_BASE_URL=https://api.schwabapi.com
SCHWAB_AUTH_URL=https://api.schwabapi.com/v1/oauth/authorize
SCHWAB_TOKEN_URL=https://api.schwabapi.com/v1/oauth/token
SCHWAB_WEBSOCKET_URL=wss://streamer.schwabapi.com/ws

# Optional: Token management
SCHWAB_AUTO_REFRESH=true
SCHWAB_REFRESH_BUFFER=300
SCHWAB_CAPTURE_CALLBACK=false

# Optional: Streaming configuration
SCHWAB_STREAMING_ENABLED=true

# For sandbox/testing (when available)
# SCHWAB_SANDBOX_MODE=true
# SCHWAB_SANDBOX_URL=https://api.schwabapi.com/sandbox